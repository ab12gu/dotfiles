# This is Git's per-user configuration file.
[user]
	name = Abhay Gupta
	email = ab18gu@gmail.com
# Please adapt and uncomment the following lines:
#	name = Abhay Gupta
#	email = ab18gu@gmail.com
[core]
	excludesfile = /Users/abhaygupta/.gitignore_global
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[alias]
    co = checkout
    cm = commit
    ss = status
    b = branch
    m = merge
